{
  "name": "salmonstats-api",
  "version": "4.0.0",
  "description": "",
  "author": "@tkgling",
  "private": true,
  "license": "MIT",
  "main": "dist/main.js",
  "engines": {
    "node": "^16.15.0",
    "yarn": "^1.22.19",
    "npm": "9.6.5"
  },
  "scripts": {
    "build": "yarn nest build",
    "format": "prettier --check --write --ignore-path .gitignore '{src,test}/**/*.{js,ts,json}'",
    "lint": "eslint --max-warnings=0 --ignore-path .gitignore '{src,test}/**/*.{js,ts}' --fix",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@fastify/helmet": "^10.1.0",
    "@fastify/static": "^6.10.1",
    "@google-analytics/data": "^3.2.2",
    "@nestjs/axios": "^2.0.0",
    "@nestjs/cli": "^9.4.2",
    "@nestjs/common": "^9.4.0",
    "@nestjs/config": "^2.2.0",
    "@nestjs/core": "^9.4.0",
    "@nestjs/platform-fastify": "^9.4.0",
    "@nestjs/swagger": "^6.3.0",
    "@nestjs/throttler": "^4.2.1",
    "@prisma/client": "^4.9.0",
    "axios": "^1.3.5",
    "big.js": "^6.2.1",
    "body-parser": "^1.20.2",
    "cache-manager": "^4.1.0",
    "camelcase-keys": "^8.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dayjs": "^1.11.5",
    "firebase": "^9.19.1",
    "nestjs-prisma": "^0.22.0",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^5.0.0",
    "rxjs": "^7.2.0",
    "snakecase-keys": "^5.4.4",
    "uuid": "^9.0.0",
    "webpack": "^5.81.0"
  },
  "devDependencies": {
    "@nestjs/schematics": "^9.1.0",
    "@nestjs/testing": "^9.4.0",
    "@types/big.js": "^6.1.6",
    "@types/cache-manager": "^4.0.2",
    "@types/express": "^4.17.13",
    "@types/jest": "29.5.1",
    "@types/js-yaml": "^4.0.5",
    "@types/node": "^18.16.3",
    "@types/supertest": "^2.0.11",
    "@typescript-eslint/eslint-plugin": "^5.59.2",
    "@typescript-eslint/parser": "^5.59.2",
    "dotenv-cli": "^7.2.1",
    "eslint": "^8.25.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-sort-keys-fix": "^1.1.2",
    "eslint-plugin-typescript-sort-keys": "^2.1.0",
    "eslint-plugin-unused-imports": "^2.0.0",
    "jest": "^29.5.0",
    "js-yaml": "^4.1.0",
    "prettier": "^2.8.8",
    "prisma": "^4.13.0",
    "source-map-support": "^0.5.20",
    "supertest": "^6.1.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.2",
    "ts-node": "^10.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.0.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
