{
  "name": "splatnet3",
  "version": "0.0.1",
  "description": "",
  "author": "@tkgling",
  "private": true,
  "license": "MIT",
  "main": "dist/index.js",
  "engines": {
    "node": "^16.15",
    "yarn": "^1.22"
  },
  "scripts": {
    "build": "yarn nest build",
    "create": "yarn prisma migrate dev --name init --create-only ",
    "deploy": "yarn prisma migrate deploy",
    "format": "prettier --write --ignore-path .gitignore './**/*.{js,ts,json}'",
    "lint": "eslint --ignore-path .gitignore './**/*.{js,ts}' --fix",
    "postreset": "yarn prisma migrate deploy",
    "prebuild": "rimraf dist",
    "reset": "yarn prisma migrate reset --force",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "start:stg": "dotenv -e .env.stg nest start --watch",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@fastify/helmet": "^10.1.0",
    "@fastify/static": "^6.10.1",
    "@google-analytics/data": "^3.2.2",
    "@nestjs/axios": "^1.0.1",
    "@nestjs/cli": "^9.4.2",
    "@nestjs/common": "^8.0.0",
    "@nestjs/config": "^2.2.0",
    "@nestjs/core": "^8.0.0",
    "@nestjs/platform-fastify": "^9.4.0",
    "@nestjs/swagger": "^6.3.0",
    "@prisma/client": "^4.9.0",
    "@types/big.js": "^6.1.6",
    "@types/node": "^16.0.0",
    "axios": "^1.3.5",
    "big.js": "^6.2.1",
    "body-parser": "^1.20.2",
    "cache-manager": "^4.1.0",
    "camelcase-keys": "^7.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.13.2",
    "dayjs": "^1.11.5",
    "firebase": "^9.19.1",
    "js-yaml": "^4.1.0",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^3.0.2",
    "rxjs": "^7.2.0",
    "snakecase-keys": "^5.4.4"
  },
  "devDependencies": {
    "@nestjs/schematics": "^8.0.0",
    "@nestjs/testing": "^8.0.0",
    "@types/cache-manager": "^4.0.2",
    "@types/express": "^4.17.13",
    "@types/jest": "27.4.1",
    "@types/supertest": "^2.0.11",
    "@typescript-eslint/eslint-plugin": "^5.47.1",
    "@typescript-eslint/parser": "^5.47.1",
    "dotenv-cli": "^6.0.0",
    "eslint": "^8.25.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-import": "^2.26.0",
    "eslint-plugin-prettier": "^4.2.1",
    "eslint-plugin-sort-keys-fix": "^1.1.2",
    "eslint-plugin-typescript-sort-keys": "^2.1.0",
    "eslint-plugin-unused-imports": "^2.0.0",
    "jest": "^27.2.5",
    "prettier": "^2.8.8",
    "prisma": "^4.13.0",
    "source-map-support": "^0.5.20",
    "supertest": "^6.1.3",
    "ts-jest": "^27.0.3",
    "ts-loader": "^9.4.1",
    "ts-node": "^10.0.0",
    "tsconfig-paths": "^3.10.1",
    "typescript": "^5.0.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
