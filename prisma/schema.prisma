// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native"]
  engineType    = "binary"
}

datasource db {
  provider = "postgres"
  url      = env("DATABASE_URL")
}

enum Rule {
  REGULAR
  BIG_RUN
  TEAM_CONTEST
}

enum Mode {
  REGULAR
  LIMITED
  PRIVATE_CUSTOM
  PRIVATE_SCENARIO
}

enum Species {
  INKLING
  OCTOLING
}

enum Client {
  SALMONIA
  SALMDROID
}

model Schedule {
  scheduleId String    @id @default(cuid()) @map("schedule_id")
  // 開始時刻
  startTime  DateTime? @map("start_time") @db.Timestamp(3)
  // 終了時刻
  endTime    DateTime? @map("end_time") @db.Timestamp(3)
  // ステージID
  stageId    Int       @map("stage_id") @db.SmallInt
  // 支給ブキID
  weaponList Int[]     @map("weapon_list")
  // モード
  mode       Mode      @default(REGULAR)
  // ルール
  rule       Rule      @default(REGULAR)
  // レアブキ
  rareWeapon Int?      @map("rare_weapon") @db.SmallInt
  // レアブキ
  bossId     Int?      @map("boss_id") @db.SmallInt
  // 作成日
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamp(3)
  // 更新日
  updatedAt  DateTime  @updatedAt() @map("updated_at") @db.Timestamp(3)
  // リザルト一覧
  results    Result[]

  @@unique([stageId, mode, rule, weaponList, startTime, endTime], name: "unique_schedule")
  @@index([stageId])
  @@index([rule])
  @@index([rule, mode])
  @@index([startTime])
  @@map("schedules")
}

model Result {
  // サーモンID
  id                   String    @id @default(cuid())
  // スケジュールID
  scheduleId           String    @map("schedule_id")
  // バイトID
  resultId             String    @map("result_id") @db.Uuid
  // プレイ時刻
  playTime             DateTime  @map("play_time") @db.Timestamp(3)
  // オオモノ出現数
  bossCounts           Int[]     @map("boss_counts")
  // オオモノ討伐数
  bossKillCounts       Int[]     @map("boss_kill_counts")
  // イクラ数
  ikuraNum             Int       @map("ikura_num") @db.SmallInt
  // 金イクラ数
  goldenIkuraNum       Int       @map("golden_ikura_num") @db.SmallInt
  // 金イクラ数
  goldenIkuraAssistNum Int       @map("golden_ikura_assist_num") @db.SmallInt
  // 夜イベントを含むかどうか
  nightLess            Boolean   @map("night_less")
  // キケン度
  dangerRate           Decimal   @map("danger_rate") @db.Decimal(4, 3)
  // プレイヤーのID配列(ソート済み)
  members              String[]
  // ドウウロコの枚数
  bronze               Int?      @db.SmallInt
  // ギンウロコの枚数
  silver               Int?      @db.SmallInt
  // キンウロコの枚数
  gold                 Int?      @db.SmallInt
  // クリアしたかどうか
  isClear              Boolean   @map("is_clear")
  // 失敗したWAVE
  failureWave          Int?      @map("failure_wave") @db.SmallInt
  // オカシラシャケを討伐したかどうか
  isBossDefeated       Boolean?  @map("is_boss_defeated")
  // たおしたオカシラシャケのID
  bossId               Int?      @map("boss_id") @db.SmallInt
  // シナリオコード
  scenarioCode         String?   @map("scenario_code")
  // 作成日
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamp(3)
  // 更新日
  updatedAt            DateTime  @updatedAt() @map("updated_at") @db.Timestamp(3)
  // アップロードしたクライアント
  createdBy            Client    @default(SALMONIA) @map("updated_by")
  // アップロードしたクライアントバージョン
  version              String
  waves                Wave[]
  players              Player[]
  schedule             Schedule? @relation(fields: [scheduleId], references: [scheduleId])

  @@unique([playTime, resultId])
  @@index([members])
  @@index([scheduleId])
  @@index([scenarioCode])
  @@index([dangerRate])
  @@index([createdBy, version])
  @@map("results")
}

model Player {
  // リザルトID
  id                   String    @map("id")
  // プレイヤーID
  nplnUserId           String    @map("npln_user_id")
  // 遊んだ時間
  playTime             DateTime  @map("play_time") @db.Timestamp(3)
  // 名前
  name                 String
  // 称号
  byname               String
  // 名前ID
  nameId               String    @map("name_id")
  // バッジ
  badges               Int[]
  // ネームプレート
  nameplate            Int
  // ネームプレート
  textColor            Decimal[] @map("text_color") @db.Decimal(12, 11)
  // ユニフォーム
  uniform              Int       @db.SmallInt
  // オオモノ討伐数合計
  bossKillCountsTotal  Int       @map("boss_kill_counts_total") @db.SmallInt
  // オオモノ討伐数
  bossKillCounts       Int[]     @map("boss_kill_counts")
  // 被救助数
  deadCount            Int       @map("dead_count") @db.SmallInt
  // 救助数
  helpCount            Int       @map("help_count") @db.SmallInt
  // イクラ数
  ikuraNum             Int       @map("ikura_num") @db.SmallInt
  // 金イクラ数
  goldenIkuraNum       Int       @map("golden_ikura_num") @db.SmallInt
  // 金イクラアシスト数
  goldenIkuraAssistNum Int       @map("golden_ikura_assist_num") @db.SmallInt
  // バイトボーナス
  jobBonus             Int?      @map("job_bonus") @db.SmallInt
  // バイトレート
  jobRate              Decimal?  @map("job_rate") @db.Decimal(3, 2)
  // バイトスコア
  jobScore             Int?      @map("job_score") @db.SmallInt
  // クマサンポイント
  kumaPoint            Int?      @map("kuma_point") @db.SmallInt
  // 称号
  gradeId              Int?      @map("grade_id") @db.SmallInt
  // 評価レート
  gradePoint           Int?      @map("grade_point") @db.SmallInt
  // オカシラメーター
  smellMeter           Int?      @map("smell_meter") @db.SmallInt
  // 種族
  species              String    @default("INKLING")
  // スペシャルID
  specialId            Int?      @map("special_id") @db.SmallInt
  // スペシャル使用数
  specialCounts        Int[]     @map("special_count")
  // 支給されたブキのリスト
  weaponList           Int[]     @map("weapon_list")
  // 作成日
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamp(3)
  // 更新日
  updatedAt            DateTime  @updatedAt() @map("updated_at") @db.Timestamp(3)
  // リレーション
  Result               Result?   @relation(fields: [id], references: [id])

  @@id([nplnUserId, id])
  @@unique([nplnUserId, playTime])
  @@index([nplnUserId])
  @@index([name])
  @@index([nameplate])
  @@index([uniform])
  @@index([gradeId])
  @@index([gradePoint])
  @@index([gradeId, gradePoint])
  @@map("players")
}

model Wave {
  // リザルトID
  id                String   @map("id")
  // WAVE数
  waveId            Int      @map("wave_id") @db.SmallInt
  // 潮位
  waterLevel        Int      @map("water_level") @db.SmallInt
  // イベント
  eventType         Int      @map("event_type") @db.SmallInt
  // 金イクラ数
  goldenIkuraNum    Int?     @map("golden_ikura_num") @db.SmallInt
  // 金イクラドロップ数
  goldenIkuraPopNum Int      @map("golden_ikura_pop_num") @db.SmallInt
  // 金イクラドロップ数
  quotaNum          Int?     @map("quota_num") @db.SmallInt
  // クリアしたか
  isClear           Boolean  @map("is_clear")
  // 作成日
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamp(3)
  // 更新日
  updatedAt         DateTime @updatedAt() @map("updated_at") @db.Timestamp(3)
  Result            Result?  @relation(fields: [id], references: [id])

  @@id([id, waveId])
  @@index([waterLevel])
  @@index([eventType])
  @@index([waterLevel, eventType])
  @@index([waterLevel, eventType, waveId])
  @@index([goldenIkuraNum])
  @@map("waves")
}
